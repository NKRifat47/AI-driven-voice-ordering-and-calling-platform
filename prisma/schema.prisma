generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum user_status {
  active
  inactive
}

enum user_role {
  SYSTEM_OWNER
  BUSINESS_OWNER
}

enum tenant_status {
  active
  suspended
  expired
}

enum subscription_status {
  active
  expired
  canceled
}

enum plan_type {
  classic
  pro
}

enum training_type {
  text
  voice
  faq
}

enum training_status {
  processing
  completed
  failed
}

enum call_type {
  ai_call
  text_call
}

enum call_status {
  completed
  failed
}

enum sender_type {
  ai
  user
}

enum billing_status {
  paid
  unpaid
}

enum billing_cycle {
  monthly
  yearly
}

model users {
  id       String @id @default(uuid())
  email    String @unique
  password String

  first_name String
  last_name  String
  avatar     String?
  gender     String?
  country    String?
  phone      String?

  role        user_role   @default(BUSINESS_OWNER)
  status      user_status @default(active)
  is_verified Boolean     @default(false)

  credits Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  owned_businesses business[]      @relation("BusinessOwner")
  user_business    user_business[]

  calls    calls[]
  training training_sessions[]

  api_keys api_keys[]
}

model business {
  id         String        @id @default(uuid())
  name       String
  owner_id   String
  status     tenant_status
  created_at DateTime      @default(now())

  owner users @relation("BusinessOwner", fields: [owner_id], references: [id])

  user_business user_business[]
  subscriptions subscriptions[]
  invoices      invoices[]
  api_keys      api_keys[]
  training      training_sessions[]
  faqs          faqs[]
  ai_samples    ai_samples[]
  calls         calls[]
  usage_logs    usage_logs[]
  settings      business_settings?
  integrations  integrations?
}

model user_business {
  id          String   @id @default(uuid())
  user_id     String
  business_id String
  role        String
  created_at  DateTime @default(now())

  user     users    @relation(fields: [user_id], references: [id])
  business business @relation(fields: [business_id], references: [id])
}

model plans {
  id            String    @id @default(uuid())
  name          plan_type
  price         Float
  call_limit    Int
  message_limit Int

  subscriptions subscriptions[]
}

model subscriptions {
  id          String              @id @default(uuid())
  business_id String
  plan_id     String
  status      subscription_status
  start_date  DateTime
  end_date    DateTime

  business business   @relation(fields: [business_id], references: [id])
  plan     plans      @relation(fields: [plan_id], references: [id])
  invoices invoices[]
}

model invoices {
  id              String         @id @default(uuid())
  business_id     String
  subscription_id String
  invoice_no      String
  amount          Float
  status          billing_status
  billing_cycle   billing_cycle
  created_at      DateTime       @default(now())

  business     business      @relation(fields: [business_id], references: [id])
  subscription subscriptions @relation(fields: [subscription_id], references: [id])
}

model api_keys {
  id          String      @id @default(uuid())
  business_id String
  api_key     String
  status      user_status
  last_used   DateTime?
  created_at  DateTime    @default(now())

  business business @relation(fields: [business_id], references: [id])
  users    users?   @relation(fields: [usersId], references: [id])
  usersId  String?
}

model training_sessions {
  id          String          @id @default(uuid())
  business_id String
  created_by  String
  type        training_type
  status      training_status
  created_at  DateTime        @default(now())

  business business         @relation(fields: [business_id], references: [id])
  user     users            @relation(fields: [created_by], references: [id])
  files    training_files[]
}

model training_files {
  id         String   @id @default(uuid())
  session_id String
  file_name  String
  file_url   String
  file_type  String
  created_at DateTime @default(now())

  session training_sessions @relation(fields: [session_id], references: [id])
}

model faqs {
  id          String   @id @default(uuid())
  business_id String
  question    String
  answer      String
  created_at  DateTime @default(now())

  business business @relation(fields: [business_id], references: [id])
}

model ai_samples {
  id          String   @id @default(uuid())
  business_id String
  content     String
  created_at  DateTime @default(now())

  business business @relation(fields: [business_id], references: [id])
}

model calls {
  id          String      @id @default(uuid())
  business_id String
  user_id     String
  type        call_type
  status      call_status
  start_time  DateTime
  end_time    DateTime
  duration    Int
  created_at  DateTime    @default(now())

  business business        @relation(fields: [business_id], references: [id])
  user     users           @relation(fields: [user_id], references: [id])
  messages call_messages[]
  summary  call_summaries?
}

model call_messages {
  id         String      @id @default(uuid())
  call_id    String
  sender     sender_type
  message    String
  created_at DateTime    @default(now())

  call calls @relation(fields: [call_id], references: [id])
}

model call_summaries {
  id         String   @id @default(uuid())
  call_id    String   @unique
  summary    String
  pdf_url    String?
  created_at DateTime @default(now())

  call calls @relation(fields: [call_id], references: [id])
}

model usage_logs {
  id             String   @id @default(uuid())
  business_id    String
  total_calls    Int
  total_messages Int
  total_duration Int
  drop_rate      Float
  date           DateTime

  business business @relation(fields: [business_id], references: [id])
}

model business_settings {
  id               String @id @default(uuid())
  business_id      String @unique
  business_name    String
  business_address String

  business business @relation(fields: [business_id], references: [id])
}

model integrations {
  id          String @id @default(uuid())
  business_id String @unique
  email       String
  phone       String

  business business @relation(fields: [business_id], references: [id])
}

model platform_settings {
  id         String   @id @default(uuid())
  logo_url   String
  updated_at DateTime @default(now())
}
